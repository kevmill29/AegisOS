#!/bin/sh
# Aegis OS v0.1 — initramfs init (PID 1).
# Everything lives in the initramfs; no root filesystem is mounted. This is a
# proof-of-boot image: kernel + busybox + aegis-agent, nothing else.

/bin/busybox --install -s /bin 2>/dev/null

mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev 2>/dev/null
mkdir -p /dev/pts /dev/shm /tmp /run
mount -t devpts none /dev/pts 2>/dev/null
mount -t tmpfs none /dev/shm
mount -t tmpfs none /tmp

# Create standard POSIX file descriptors for bash process substitution
ln -sf /proc/self/fd /dev/fd
ln -sf /proc/self/fd/0 /dev/stdin
ln -sf /proc/self/fd/1 /dev/stdout
ln -sf /proc/self/fd/2 /dev/stderr

# cgroup v2 unified hierarchy — the agent's whole control surface.
mount -t cgroup2 none /sys/fs/cgroup
echo "+cpu +memory +pids" > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null

# Parse a key from the kernel command line, e.g. cmdline_val aegis.hostname.
# Install-time options are baked into the bootloader's APPEND line, so the
# installed system carries the choices the user made — the OS still runs from
# RAM identically, only these knobs differ.
cmdline_val() {
  for tok in $(cat /proc/cmdline); do
    case "$tok" in "$1"=*) echo "${tok#*=}"; return;; esac
  done
}

# Silence asynchronous kernel logs so they don't overwrite our interactive TUI
dmesg -n 1

# If booted from the "Install Aegis" menu entry, hand off to the installer and
# never start the agent — a live/agent boot and an install boot are the same
# kernel+initramfs, distinguished only by this flag on the command line.
for tok in $(cat /proc/cmdline); do
  if [ "$tok" = "aegis.install" ]; then
    sleep 2
    exec cttyhack /usr/bin/aegis-install
  fi
done

# Hostname is an install option (aegis.hostname=...), default "aegis".
hostname "$(cmdline_val aegis.hostname || echo aegis)"

# Networking: loopback (the agent's event bus binds 127.0.0.1 — this is not
# optional), then DHCP on every wired interface that exists. udhcpc stays
# resident to renew the lease; -b backgrounds it if no cable is plugged in.
ifconfig lo 127.0.0.1 up
for iface in /sys/class/net/*; do
  iface="$(basename "$iface")"
  case "$iface" in
    lo) ;;
    *) ifconfig "$iface" up 2>/dev/null
       udhcpc -b -i "$iface" -s /etc/udhcpc.script -t 3 -T 3 >/dev/null 2>&1 &
       ;;
  esac
done

echo ""
echo "  ================================================"
echo "   AEGIS OS v0.1 — Core Agent boot image"
echo "  ================================================"
echo ""

# Determine root device from cmdline (for installed systems)
ROOT_DEV="$(cmdline_val root)"

if [ -n "$ROOT_DEV" ]; then
    echo "Booting from installed root: $ROOT_DEV"
    mkdir -p /newroot
    
    # Wait for the root device to appear
    while [ ! -b "$ROOT_DEV" ]; do sleep 0.1; done
    
    mount "$ROOT_DEV" /newroot || fail "Failed to mount root $ROOT_DEV"
    
    # Move essential mounts to the new root
    mount --move /proc /newroot/proc
    mount --move /sys /newroot/sys
    mount --move /dev /newroot/dev
    mount --move /run /newroot/run
    
    # Launch the agent in the new root via cgroup setup before switch_root
    mkdir -p /newroot/sys/fs/cgroup/aegis
    (
      echo $$ > /newroot/sys/fs/cgroup/aegis/cgroup.procs
      exec chroot /newroot env RUST_LOG=info /usr/bin/aegis-agent > /newroot/dev/console 2>&1
    ) &
    
    echo "  aegis-agent started"
    echo "  Switching root to installed OS..."
    exec switch_root /newroot /usr/bin/bash
else
    # We need to find and mount the boot medium (CD-ROM/USB) to access rootfs.sfs.
    echo "Waiting for boot medium..."
    while [ ! -b /dev/sr0 ] && [ ! -b /dev/sda ]; do
        sleep 0.1
    done

    mkdir -p /run/bootmedia
    mount -o ro /dev/sr0 /run/bootmedia 2>/dev/null || mount -o ro /dev/sda /run/bootmedia 2>/dev/null

    if [ -f /run/bootmedia/rootfs.sfs ]; then
        echo "Found rootfs.sfs. Assembling OverlayFS..."
        mkdir -p /run/rootfs_ro
        mkdir -p /run/rootfs_rw
        mkdir -p /run/rootfs_work
        mkdir -p /newroot
        
        # Mount the read-only squashfs
        mount -t squashfs -o ro /run/bootmedia/rootfs.sfs /run/rootfs_ro
        
        # Create the writable RAM overlay (this is where Steam installs games for the live session)
        mount -t tmpfs -o size=8G none /run/rootfs_rw
        mkdir -p /run/rootfs_rw/upper
        mkdir -p /run/rootfs_rw/work
        
        # Assemble the overlayfs
        mount -t overlay overlay -o lowerdir=/run/rootfs_ro,upperdir=/run/rootfs_rw/upper,workdir=/run/rootfs_rw/work /newroot
        
        # Move essential mounts to the new root
        mount --move /proc /newroot/proc
        mount --move /sys /newroot/sys
        mount --move /dev /newroot/dev
        mount --move /run /newroot/run
        
        # Launch the agent in the new root via cgroup setup before switch_root
        mkdir -p /newroot/sys/fs/cgroup/aegis
        (
          echo $$ > /newroot/sys/fs/cgroup/aegis/cgroup.procs
          exec chroot /newroot env RUST_LOG=info /usr/bin/aegis-agent > /newroot/dev/console 2>&1
        ) &
        
        echo "  aegis-agent started inside overlayfs"
        echo "  Switching root to gaming userland..."
        
        exec switch_root /newroot /usr/bin/bash
    else
        echo "rootfs.sfs not found! Falling back to busybox initramfs."
        
        # Launch the agent inside its own cgroup (fallback path)
        mkdir -p /sys/fs/cgroup/aegis
        (
          echo $$ > /sys/fs/cgroup/aegis/cgroup.procs
          exec env RUST_LOG=info /usr/bin/aegis-agent > /dev/console 2>&1
        ) &
    fi
fi

echo "  aegis-agent started (cgroup: /sys/fs/cgroup/aegis · host $(hostname))"
echo "  try:  fake-game    (simulates a 10s Proton game session)"
echo ""

# Boot mode is an install option. "headless" keeps the agent running with no
# interactive shell (an appliance); the default drops to a respawning shell on
# /dev/console (whichever console= the boot entry chose — tty0 on hardware,
# ttyS0 for serial/QEMU). We deliberately don't also spawn a getty on ttyS0:
# with console=ttyS0 that produced two shells fighting over the same keystrokes.
if [ "$(cmdline_val aegis.boot)" = "headless" ]; then
  echo "  boot mode: headless — agent only, no shell"
  while true; do sleep 3600; done
else
  while true; do
    setsid cttyhack /bin/sh
    sleep 1
  done
fi
