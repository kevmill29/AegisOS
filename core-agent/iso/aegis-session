#!/usr/bin/env bash
# Aegis OS graphical session: cage (Wayland kiosk) running the Electron
# frontend fullscreen — the Phase 3 "working path" from launch-kiosk.sh,
# now booted on the real target instead of a dev desktop.
# Runs as root under aegis-init; exits (and is respawned/judged) on failure.
set -u

export HOME=/root
export XDG_RUNTIME_DIR=/run/aegis
mkdir -p "$XDG_RUNTIME_DIR"
chmod 0700 "$XDG_RUNTIME_DIR"

# There is no systemd running: bring up udev by hand so libinput can
# enumerate keyboards/mice and the DRM device gets its /dev node.
if ! pgrep -x systemd-udevd >/dev/null 2>&1; then
  /usr/lib/systemd/systemd-udevd --daemon 2>/dev/null
  udevadm trigger --action=add 2>/dev/null
  udevadm settle --timeout=10 2>/dev/null
fi

# Give the DRM device a moment on slow VMs, then bail with a clear message —
# aegis-init counts fast exits and falls back to the console shell.
for _ in $(seq 1 20); do
  [ -e /dev/dri/card0 ] && break
  sleep 0.5
done
if [ ! -e /dev/dri/card0 ]; then
  echo "aegis-session: no /dev/dri/card0 — kernel has no KMS driver for this GPU" >&2
  exit 1
fi

# Seat management: Arch builds libseat WITHOUT the builtin backend ("No
# backend matched name 'builtin'"), so run the seatd daemon and use it.
# Keep builtin as a fallback for distros that do compile it in.
if command -v seatd >/dev/null 2>&1; then
  if ! pgrep -x seatd >/dev/null 2>&1; then
    seatd 2>/dev/null &
    sleep 0.5
  fi
  export LIBSEAT_BACKEND=seatd
else
  export LIBSEAT_BACKEND=builtin
fi

# Audio: bring up PipeWire so games actually have an output sink (and the
# sphere has a real source to react to later). All non-fatal — with no audio
# the session still runs and the sphere falls back to its synthetic beat.
# Sockets live under XDG_RUNTIME_DIR (set above); wireplumber is the session/
# policy manager, and pipewire-pulse gives Chromium/Electron a PulseAudio
# server to talk to. Started before the frontend so the socket exists when
# Electron probes for audio, and outside dbus-run-session on purpose — routing
# is via the XDG_RUNTIME_DIR socket, which the frontend inherits regardless.
if command -v pipewire >/dev/null 2>&1 && ! pgrep -x pipewire >/dev/null 2>&1; then
  mkdir -p /var/log
  pipewire       >/var/log/aegis-audio.log 2>&1 &
  sleep 0.5
  wireplumber    >>/var/log/aegis-audio.log 2>&1 &
  pipewire-pulse >>/var/log/aegis-audio.log 2>&1 &

  # Point the default capture source at the default sink's monitor, so the
  # frontend's getUserMedia() hears what's playing (game/music) instead of a
  # (nonexistent) microphone. Best-effort and backgrounded: wait for the sink
  # and its monitor to exist, set it, and give up quietly after 20s. pactl
  # ships with libpulse; the "<sink>.monitor" name is pipewire-pulse's standard
  # monitor naming.
  (
    for _ in $(seq 1 20); do
      sink="$(pactl get-default-sink 2>/dev/null)"
      if [ -n "$sink" ] && pactl list short sources 2>/dev/null | grep -q "${sink}.monitor"; then
        pactl set-default-source "${sink}.monitor" 2>/dev/null && break
      fi
      sleep 1
    done
  ) >>/var/log/aegis-audio.log 2>&1 &
fi

# Software rendering must be allowed — simpledrm has no GPU accel. And force
# the pixman renderer outright: VM GPUs (vmwgfx et al) fail EGL device
# creation ("eglQueryDevicesEXT: Failed to allocate device"), and pixman
# needs no EGL at all. Electron software-renders into shm buffers anyway.
export WLR_RENDERER_ALLOW_SOFTWARE=1
export WLR_RENDERER=pixman
export AEGIS_KIOSK=1

# Electron as root needs --no-sandbox; native Wayland via ozone. dbus-run-session
# gives Chromium the session bus it expects (cuts startup stalls and warnings).
# WebGL on GPU-less targets: NOT --disable-gpu (that reports GL_VENDOR=Disabled
# and kills WebGL outright — lab-verified); ANGLE-on-SwiftShader instead, which
# Chromium 128+ additionally gates behind --enable-unsafe-swiftshader.
# Log to a file: cage owns the screen, so console output is invisible exactly
# when it matters; aegis-init prints this log's tail on crashloop fallback.
mkdir -p /var/log
echo "--- aegis-session $(date 2>/dev/null) ---" >> /var/log/aegis-session.log
# Route Chromium's own stderr logging into the same file — without this an
# Electron that hangs before mapping a window leaves no trace at all.
export ELECTRON_ENABLE_LOGGING=1
exec dbus-run-session -- cage -- electron /opt/aegis/frontend \
  --no-sandbox \
  --ozone-platform=wayland \
  --enable-features=UseOzonePlatform,WaylandWindowDecorations \
  --use-gl=angle \
  --use-angle=swiftshader \
  --enable-unsafe-swiftshader \
  >> /var/log/aegis-session.log 2>&1
