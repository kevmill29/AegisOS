#!/usr/bin/env bash
# Aegis sphere kiosk session. Launched *inside* cage by greetd, as the
# unprivileged `aegis` user (see /etc/greetd/config.toml). greetd gives us a
# real logind session, so cage already owns the DRM device and WAYLAND_DISPLAY
# is set — this script only starts audio and the Electron sphere.
#
# Why not root: Steam refuses to run as root, and PipeWire/WirePlumber are
# designed to run in a per-user session (running them as root broke device /
# headset detection). Everything here therefore runs as `aegis`.
set -u

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export AEGIS_KIOSK=1
# wlroots software-render fallback for VMs / GPUs without EGL accel (cage, which
# greetd launched, already honors this; on real GPU hardware it uses the fast path).
export WLR_RENDERER_ALLOW_SOFTWARE=1

# Audio, as this user (the correct way — root broke headset enumeration):
# PipeWire graph + WirePlumber (device/policy manager) + pipewire-pulse (the
# PulseAudio server Chromium/Electron talks to). Then point the default capture
# at the default sink's monitor so the sphere reacts to whatever is playing
# (game/music) instead of a real mic. All non-fatal.
mkdir -p "$XDG_RUNTIME_DIR" 2>/dev/null || true
if command -v pipewire >/dev/null 2>&1 && ! pgrep -x -U "$(id -u)" pipewire >/dev/null 2>&1; then
  mkdir -p "$HOME/.local/state" 2>/dev/null || true
  pipewire        >"$HOME/aegis-audio.log" 2>&1 &
  sleep 0.5
  wireplumber     >>"$HOME/aegis-audio.log" 2>&1 &
  pipewire-pulse  >>"$HOME/aegis-audio.log" 2>&1 &
  (
    for _ in $(seq 1 30); do
      sink="$(pactl get-default-sink 2>/dev/null)"
      if [ -n "$sink" ] && [ "$sink" != "auto_null" ] \
         && pactl list short sources 2>/dev/null | grep -q "${sink}.monitor"; then
        pactl set-default-source "${sink}.monitor" 2>/dev/null && break
      fi
      sleep 1
    done
  ) >>"$HOME/aegis-audio.log" 2>&1 &
fi

# Electron: native Wayland via ozone; WebGL on GPU-less targets via
# ANGLE-on-SwiftShader (NOT --disable-gpu, which kills WebGL). --no-sandbox keeps
# startup robust in the minimal kiosk. cage is the compositor; Electron is its
# only client, fullscreen. dbus-run-session gives Chromium its session bus.
export ELECTRON_ENABLE_LOGGING=1
exec dbus-run-session -- electron /opt/aegis/frontend \
  --no-sandbox \
  --ozone-platform=wayland \
  --enable-features=UseOzonePlatform,WaylandWindowDecorations \
  --use-gl=angle \
  --use-angle=swiftshader \
  --enable-unsafe-swiftshader
