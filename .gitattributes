# Everything under core-agent/iso ships byte-for-byte into the initramfs/ISO;
# CRLF endings there make the kernel panic on boot ("Failed to execute /init").
# Force LF so a Windows checkout (core.autocrlf) can never reintroduce them.
*.sh text eol=lf
core-agent/iso/** text eol=lf
core-agent/archiso/** text eol=lf
compositor/launch-kiosk.sh text eol=lf
